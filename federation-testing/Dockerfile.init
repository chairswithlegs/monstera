# Image for federation-testing init containers only (migrate + seed).
# The seed binary runs store.RunUp (migrations) then seeds users. Not used in production.
FROM golang:1.26-alpine AS builder
RUN apk add --no-cache ca-certificates
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /seed ./cmd/seed

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /seed /seed
USER nobody
ENTRYPOINT ["/seed"]
